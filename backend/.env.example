# PostgreSQL connection string (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/football_odds

# Redis connection string
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Third-Party API Keys — fill in your own keys from each provider's dashboard
# ---------------------------------------------------------------------------

# The Odds API → https://the-odds-api.com/account/
ODDS_API_KEY=

# API-Football (via RapidAPI) → https://rapidapi.com/api-sports/api/api-football
API_FOOTBALL_KEY=

# Sportmonks → https://my.sportmonks.com/tokens
SPORTMONKS_API_TOKEN=
